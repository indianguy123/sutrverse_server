generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Salon {
  id             String           @id @default(cuid())
  name           String
  timezone       String           // e.g. "Asia/Kolkata"
  address        String?
  phone          String?
  email          String?          // used as reply-to in confirmation emails
  operatingHours OperatingHours[]
  stylists       Stylist[]
  createdAt      DateTime         @default(now())
}

model OperatingHours {
  id        String  @id @default(cuid())
  salonId   String
  salon     Salon   @relation(fields: [salonId], references: [id])
  dayOfWeek Int     // 0 = Sunday, 6 = Saturday
  openTime  String  // "09:00" (HH:mm, local time string)
  closeTime String  // "18:00"
  isClosed  Boolean @default(false)
}

model Stylist {
  id           String        @id @default(cuid())
  salonId      String
  salon        Salon         @relation(fields: [salonId], references: [id])
  userId       String?       @unique
  user         User?         @relation(fields: [userId], references: [id])
  name         String
  bio          String?
  photoUrl     String?
  specialties  String[]
  slotDuration Int           @default(30)
  isActive     Boolean       @default(true)
  appointments Appointment[]
  createdAt    DateTime      @default(now())

  @@index([salonId, isActive])
}

model Appointment {
  id             String            @id @default(cuid())
  stylistId      String
  stylist        Stylist           @relation(fields: [stylistId], references: [id])
  customerName   String
  customerPhone  String
  customerEmail  String?
  service        String
  startTime      DateTime
  endTime        DateTime
  status         AppointmentStatus @default(CONFIRMED)
  isWalkIn       Boolean           @default(false)
  notes          String?
  price          Decimal?
  idempotencyKey String?           @unique
  createdAt      DateTime          @default(now())

  @@unique([stylistId, startTime])
  @@index([stylistId, startTime, endTime])
  @@index([stylistId, status])
  @@index([createdAt])
}

enum AppointmentStatus {
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  role     Role     @default(STYLIST)
  stylist  Stylist?
}

enum Role {
  OWNER
  STYLIST
}
